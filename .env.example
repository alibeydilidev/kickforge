# KickForge Environment Variables
# Copy this file to .env and fill in your values.
# Get your credentials at: https://kick.com/settings/developer

KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
KICK_BROADCASTER_ID=

# Chatroom ID for Pusher WebSocket mode.
# Optional — KickForge tries to auto-resolve it from the channel slug,
# but if the lookup fails (e.g. API changes) it falls back to this value.
# Find yours at: https://kick.com/api/v2/channels/YOUR_SLUG (look for chatroom.id)
KICK_CHATROOM_ID=

# Your channel slug — used by examples/minimal_bot.py as the default channel.
# KICK_CHANNEL=

# Webhook URL — set this in your Kick Developer App settings, NOT here.
# This is just a reminder for you to copy your ngrok URL there.
# Example: https://abc123.ngrok-free.app/webhook
# KICK_WEBHOOK_URL=
